@Composable
fun LabScreen() {
    val scrollState = rememberScrollState()

    val c = Calendar.getInstance()
    val hour = c.get(Calendar.HOUR_OF_DAY)
    val minute = c.get(Calendar.MINUTE)
    val year = c.get(Calendar.YEAR)

    val developers = stringArrayResource(R.array.developers)

    // Правильный plurals: передаём количество ДВАЖДЫ (для выбора формы + для %d)
    val hoursText = pluralStringResource(R.plurals.hours, hour, hour)
    val minutesText = pluralStringResource(R.plurals.minutes, minute, minute)

    Column(modifier = Modifier.fillMaxSize()) {

        // Фиксированная верхняя панель (по ТЗ 5.1.3)
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(horizontal = 16.dp, vertical = 12.dp),
            verticalAlignment = Alignment.CenterVertically,
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            Text(
                text = stringResource(R.string.app_name),
                style = MaterialTheme.typography.titleMedium.copy(fontFamily = CustomFontFamily),
                maxLines = 1,
                overflow = TextOverflow.Ellipsis,
                modifier = Modifier.weight(1f)  // название слева, не обрезается сильно
            )

            TextField(
                value = "",
                onValueChange = {},
                placeholder = { Text(stringResource(R.string.search)) },
                modifier = Modifier
                    .weight(2.5f)               // поиск занимает больше места
                    .height(dimensionResource(R.dimen.search_height)),
                singleLine = true,
                colors = TextFieldDefaults.colors(
                    focusedContainerColor = colorResource(R.color.search_bg),
                    unfocusedContainerColor = colorResource(R.color.search_bg),
                    focusedIndicatorColor = Color.Transparent,
                    unfocusedIndicatorColor = Color.Transparent
                )
            )

            IconButton(
                onClick = { /* ничего */ },
                modifier = Modifier.size(48.dp)
            ) {
                Icon(
                    painter = painterResource(R.drawable.cat),  // твоя векторная кошка
                    contentDescription = stringResource(R.string.menu),
                    tint = colorResource(R.color.primary),
                    modifier = Modifier.size(dimensionResource(R.dimen.vector_icon_size))
                )
            }
        }

        // Скроллируемая часть — ВСЁ остальное
        Column(
            modifier = Modifier
                .fillMaxWidth()
                .weight(1f)
                .verticalScroll(scrollState)
                .padding(16.dp),
            horizontalAlignment = Alignment.CenterHorizontally,
            verticalArrangement = Arrangement.spacedBy(32.dp)
        ) {
            // Текущее время — без повторений и %d
            Text(
                text = "$hour $hoursText $minute $minutesText",
                style = MaterialTheme.typography.headlineSmall.copy(fontFamily = CustomFontFamily),
                color = colorResource(R.color.primary)
            )

            // Векторное изображение
            Text(
                text = "Векторная иконка (XML)",
                fontFamily = CustomFontFamily,
                style = MaterialTheme.typography.titleMedium
            )
            Image(
                painter = painterResource(R.drawable.cat),
                contentDescription = null,
                modifier = Modifier
                    .size(dimensionResource(R.dimen.image_size))
                    .background(colorResource(R.color.accent)),
                colorFilter = ColorFilter.tint(colorResource(R.color.primary))
            )

            // Растровое изображение — строго круглое
            Text(
                text = "Растровое изображение (PNG/JPG) — круглое",
                fontFamily = CustomFontFamily,
                style = MaterialTheme.typography.titleMedium
            )
            Image(
                painter = painterResource(R.drawable.cat),  // ← если JPG/PNG, имя то же
                contentDescription = null,
                modifier = Modifier
                    .size(dimensionResource(R.dimen.image_size))  // 120dp или больше
                    .clip(CircleShape)                            // главное — clip
                    .border(2.dp, Color.Gray, CircleShape)        // опционально рамка, чтобы видно было круг
            )

            Spacer(modifier = Modifier.weight(1f))  // толкает копирайт вниз

            // Копирайт — в самом низу (по скрину логично)
            developers.forEach { dev ->
                Text(
                    text = stringResource(R.string.copyright, dev, year),
                    fontFamily = CustomFontFamily,
                    style = MaterialTheme.typography.bodyMedium,
                    color = colorResource(R.color.text)
                )
            }

            Text(
                "Все элементы используют ресурсы",
                fontFamily = CustomFontFamily,
                style = MaterialTheme.typography.bodySmall
            )
        }
    }
}
