@Composable
fun Lab16Screen() {
    val scrollState = rememberScrollState()

    // Текущее время (как в задании)
    val c = Calendar.getInstance()
    val hour = c.get(Calendar.HOUR_OF_DAY)
    val minute = c.get(Calendar.MINUTE)
    val year = c.get(Calendar.YEAR)

    val developers = stringArrayResource(R.array.developers)

    Column(modifier = Modifier.fillMaxSize()) {

        // Верхняя фиксированная часть
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(16.dp),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = stringResource(R.string.app_name),
                style = MaterialTheme.typography.titleLarge.copy(fontFamily = CustomFontFamily),
                color = colorResource(R.color.text)
            )

            TextField(
                value = "",
                onValueChange = {},
                placeholder = { Text(stringResource(R.string.search)) },
                modifier = Modifier
                    .weight(1f)
                    .padding(horizontal = 8.dp)
                    .height(dimensionResource(R.dimen.search_height)),
                colors = TextFieldDefaults.colors(
                    unfocusedContainerColor = colorResource(R.color.search_bg)
                )
            )

            IconButton(
                onClick = { /* меню */ },
                modifier = Modifier.size(dimensionResource(R.dimen.menu_button_size))
            ) {
                Icon(
                    painter = painterResource(R.drawable.cat),  // ← твоя векторная кошка
                    contentDescription = stringResource(R.string.menu),
                    tint = colorResource(R.color.primary),      // цвет задаём tint'ом
                    modifier = Modifier.size(dimensionResource(R.dimen.vector_icon_size))
                )
            }
        }

        // Скроллируемый контент
        Column(
            modifier = Modifier
                .weight(1f)
                .verticalScroll(scrollState)
                .padding(16.dp),
            verticalArrangement = Arrangement.spacedBy(16.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            // Форматированные строки с разработчиками
            developers.forEach { dev ->
                Text(
                    text = stringResource(R.string.copyright, dev, year),
                    style = TextStyle(fontFamily = CustomFontFamily),
                    color = colorResource(R.color.text)
                )
            }

            // Время с plurals
            val hoursStr = pluralStringResource(R.plurals.hours, hour)
            val minutesStr = pluralStringResource(R.plurals.minutes, minute)
            Text(
                text = "$hour $hoursStr $minute $minutesStr",
                style = MaterialTheme.typography.headlineMedium.copy(fontFamily = CustomFontFamily),
                color = colorResource(R.color.primary)
            )

            Spacer(modifier = Modifier.height(16.dp))

            // Векторная кошка (cat.svg → cat.xml) с размером и цветом
            Text("Векторная иконка-кошка (из SVG):", fontFamily = CustomFontFamily)
            Image(
                painter = painterResource(R.drawable.cat),
                contentDescription = "Векторная кошка",
                modifier = Modifier
                    .size(dimensionResource(R.dimen.image_size))
                    .background(colorResource(R.color.accent)),
                colorFilter = ColorFilter.tint(colorResource(R.color.primary))  // tint для монохрома
            )

            Spacer(modifier = Modifier.height(24.dp))

            // Растровая кошка (cat.png) — круглая
            Text("Растровое фото кошки (из PNG) — круглое:", fontFamily = CustomFontFamily)
            Image(
                painter = painterResource(R.drawable.cat),
                contentDescription = "Круглая кошка",
                modifier = Modifier
                    .size(dimensionResource(R.dimen.image_size))
                    .clip(CircleShape)
            )

            Spacer(modifier = Modifier.height(16.dp))

            // Пример кнопки и текста с твоим шрифтом
            Button(
                onClick = {},
                colors = ButtonDefaults.buttonColors(containerColor = colorResource(R.color.primary))
            ) {
                Text("Кнопка", fontFamily = CustomFontFamily)
            }

            Text(
                text = "Всё использует ресурсы",
                color = colorResource(R.color.text),
                fontFamily = CustomFontFamily
            )
        }
    }
}
