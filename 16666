@Composable
fun LabScreen() {
    val scrollState = rememberScrollState()

    val calendar = Calendar.getInstance()
    val hour = calendar.get(Calendar.HOUR_OF_DAY)
    val minute = calendar.get(Calendar.MINUTE)
    val year = calendar.get(Calendar.YEAR)

    val developers = stringArrayResource(R.array.developers)

    // Правильное получение plurals с подстановкой %d
    val hoursText = pluralStringResource(R.plurals.hours, hour, hour)
    val minutesText = pluralStringResource(R.plurals.minutes, minute, minute)

    Column(modifier = Modifier.fillMaxSize()) {

        // Верхняя панель — фиксированная
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .padding(16.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = stringResource(R.string.app_name),
                style = MaterialTheme.typography.titleLarge.copy(fontFamily = CustomFontFamily),
                modifier = Modifier.weight(1f)  // ← название занимает место слева
            )

            TextField(
                value = "",
                onValueChange = {},
                placeholder = { Text(stringResource(R.string.search)) },
                modifier = Modifier
                    .weight(3f)           // ← поле поиска шире (или .fillMaxWidth(0.6f))
                    .height(dimensionResource(R.dimen.search_height))
                    .padding(horizontal = 8.dp),
                colors = TextFieldDefaults.colors(
                    unfocusedContainerColor = colorResource(R.color.search_bg)
                )
            )

            IconButton(
                onClick = { },
                modifier = Modifier.size(dimensionResource(R.dimen.menu_button_size))
            ) {
                Icon(
                    painter = painterResource(R.drawable.cat),
                    contentDescription = stringResource(R.string.menu),
                    tint = colorResource(R.color.primary),
                    modifier = Modifier.size(dimensionResource(R.dimen.vector_icon_size))
                )
            }
        }

        // Скроллируемый контент
        Column(
            modifier = Modifier
                .weight(1f)
                .verticalScroll(scrollState)
                .padding(16.dp),
            verticalArrangement = Arrangement.spacedBy(24.dp),
            horizontalAlignment = Alignment.CenterHorizontally
        ) {
            // Текущее время (теперь без %d)
            Text(
                text = "$hour $hoursText $minute $minutesText",
                style = MaterialTheme.typography.headlineMedium.copy(fontFamily = CustomFontFamily),
                color = colorResource(R.color.primary)
            )

            Spacer(Modifier.height(32.dp))

            Text("Векторная иконка (SVG → XML)", fontFamily = CustomFontFamily)
            Image(
                painter = painterResource(R.drawable.cat),
                contentDescription = null,
                modifier = Modifier
                    .size(dimensionResource(R.dimen.image_size))
                    .background(colorResource(R.color.accent)),
                colorFilter = ColorFilter.tint(colorResource(R.color.primary))
            )

            Spacer(Modifier.height(40.dp))

            Text("Растровое изображение (PNG) — круглое", fontFamily = CustomFontFamily)
            Image(
                painter = painterResource(R.drawable.cat),
                contentDescription = null,
                modifier = Modifier
                    .size(dimensionResource(R.dimen.image_size))
                    .clip(CircleShape)
            )

            Spacer(Modifier.weight(1f))  // ← толкает копирайт вниз

            // Копирайт в самом низу (для каждого разработчика)
            developers.forEach { dev ->
                Text(
                    text = stringResource(R.string.copyright, dev, year),
                    style = MaterialTheme.typography.bodyMedium.copy(fontFamily = CustomFontFamily),
                    color = colorResource(R.color.text)
                )
            }

            Text(
                "Все элементы используют ресурсы",
                fontFamily = CustomFontFamily,
                color = colorResource(R.color.text)
            )
        }
    }
}
