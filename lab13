@Composable
fun Task3BoxLayout() {
    Box(
        modifier = Modifier
            .fillMaxSize()
            .background(Color.Black)  // Фон чёрный, как на рисунке
    ) {
        // Цветные блоки в разных позициях (примерно по рисунку: углы, центр, наложения)
        Box(modifier = Modifier.align(Alignment.TopStart).size(50.dp).background(Color.Red))
        Box(modifier = Modifier.align(Alignment.TopCenter).size(50.dp).background(Color.Cyan))
        Box(modifier = Modifier.align(Alignment.TopEnd).size(50.dp).background(Color.Yellow))
        Box(modifier = Modifier.align(Alignment.CenterStart).size(50.dp).background(Color.Green))
        Box(modifier = Modifier.align(Alignment.Center).size(50.dp).background(Color.Magenta))
        Box(modifier = Modifier.align(Alignment.CenterEnd).size(50.dp).background(Color.Blue))
        Box(modifier = Modifier.align(Alignment.BottomStart).size(50.dp).background(Color(0xFF00FF00)))  // Lime
        Box(modifier = Modifier.align(Alignment.BottomCenter).size(50.dp).background(Color.Gray))
        Box(modifier = Modifier.align(Alignment.BottomEnd).size(50.dp).background(Color(0xFFFF00FF)))  // Fuchsia
