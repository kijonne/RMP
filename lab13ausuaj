@Composable
fun Task3Box() {
    Box(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp)
    ) {
        // Красная рамка
        Box(
            modifier = Modifier
                .fillMaxSize()
                .border(4.dp, Color.Red)
        )

        // Синяя рамка
        Box(
            modifier = Modifier
                .fillMaxSize(0.9f)
                .align(Alignment.Center)
                .border(4.dp, Color.Blue)
        )

        // Чёрный квадрат в центре
        Box(
            modifier = Modifier
                .size(180.dp)
                .align(Alignment.Center)
                .background(Color.Black)
        )

        // Дополнительные цветные полосы по краям (как на рисунке 1)
        Box(
            modifier = Modifier
                .width(40.dp)
                .fillMaxHeight()
                .align(Alignment.CenterStart)
                .background(Color(0xFF00FF00))
        )
        Box(
            modifier = Modifier
                .width(40.dp)
                .fillMaxHeight()
                .align(Alignment.CenterEnd)
                .background(Color(0xFFFFA500))
        )
        Box(
            modifier = Modifier
                .height(40.dp)
                .fillMaxWidth()
                .align(Alignment.TopCenter)
                .background(Color.White)
        )
        Box(
            modifier = Modifier
                .height(40.dp)
                .fillMaxWidth()
                .align(Alignment.BottomCenter)
                .background(Color.Magenta)
        )
    }
}

