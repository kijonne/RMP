// Задание 5.2
@Composable
fun PinCodeScreen() {
    var pinInput by remember { mutableStateOf("") }
    var attempts by remember { mutableStateOf(3) }
    var result by remember { mutableStateOf("") }
    val correctPin = "1234"
    val isBlocked = attempts <= 0

    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp),
        horizontalAlignment = Alignment.CenterHorizontally
    ) {
        Text("Введите PIN-код (4 цифры)", style = MaterialTheme.typography.titleMedium)

        OutlinedTextField(
            value = pinInput,
            onValueChange = {
                if (it.length <= 4 && it.all { char -> char.isDigit() }) {
                    pinInput = it
                }
            },
            label = { Text("PIN-код") },
            keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.NumberPassword),
            visualTransformation = PasswordVisualTransformation(),
            enabled = !isBlocked,
            modifier = Modifier.fillMaxWidth()
        )

        Button(
            onClick = {
                if (pinInput.length == 4) {
                    if (pinInput == correctPin) {
                        result = "Верно!"
                        attempts = 3
                        pinInput = ""
                    } else {
                        attempts--
                        result = if (attempts > 0) "Неверно. Осталось попыток: $attempts" else "Попытки исчерпаны"
                    }
                }
            },
            enabled = !isBlocked && pinInput.length == 4,
            modifier = Modifier.fillMaxWidth()
        ) {
            Text("Отправить")
        }

        Text(
            text = when {
                isBlocked -> "Ввод заблокирован"
                result.isNotEmpty() -> result
                else -> "Попыток осталось: $attempts"
            },
            color = if (isBlocked) Color.Red else Color.Unspecified
        )
    }
}

