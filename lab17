@Composable
fun AboutMeScreen() {
    var aboutText by remember { mutableStateOf("") }
    val maxLength = 300

    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(8.dp)
    ) {
        Text("О себе (макс. 300 символов)", style = MaterialTheme.typography.titleMedium)

        OutlinedTextField(
            value = aboutText,
            onValueChange = {
                if (it.length <= maxLength) aboutText = it
            },
            label = { Text("Введите текст") },
            placeholder = { Text("Расскажите о себе...") },
            maxLines = 10,
            modifier = Modifier.fillMaxWidth()
        )

        Text(
            text = "${maxLength - aboutText.length} символов осталось",
            style = MaterialTheme.typography.bodySmall
        )
    }
}

// Задание 5.3.3 + 5.3.4 + 5.3.5 + 5.4 + 5.5
@Composable
fun FontSettingsScreen() {
    val colors = listOf(
        "Чёрный" to Color.Black,
        "Красный" to Color.Red,
        "Синий" to Color.Blue,
        "Зелёный" to Color.Green,
        "Фиолетовый" to Color(0xFF9C27B0)
    )

    var selectedColor by remember { mutableStateOf(Color.Black) }
    var fontSize by remember { mutableStateOf(16f) }
    var isBold by remember { mutableStateOf(false) }
    var isItalic by remember { mutableStateOf(false) }

    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        Text(
            text = "Пример текста с настройками шрифта",
            fontSize = fontSize.sp,
            fontWeight = if (isBold) FontWeight.Bold else FontWeight.Normal,
            fontStyle = if (isItalic) FontStyle.Italic else FontStyle.Normal,
            color = selectedColor
        )

        // RadioButton для цвета
        Text("Цвет текста:", style = MaterialTheme.typography.titleSmall)
        colors.forEach { (label, color) ->
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .selectable(
                        selected = selectedColor == color,
                        onClick = { selectedColor = color }
                    )
                    .padding(vertical = 4.dp),
                verticalAlignment = Alignment.CenterVertically
            ) {
                RadioButton(
                    selected = selectedColor == color,
                    onClick = { selectedColor = color }
                )
                Text(label, modifier = Modifier.padding(start = 8.dp))
                Spacer(modifier = Modifier.width(12.dp))
                Box(
                    modifier = Modifier
                        .size(24.dp)
                        .background(color)
                )
            }
        }

        // Slider
        Text("Размер шрифта: ${fontSize.toInt()}", style = MaterialTheme.typography.titleSmall)
        Slider(
            value = fontSize,
            onValueChange = { fontSize = it },
            valueRange = 10f..30f,
            steps = 19,
            modifier = Modifier.fillMaxWidth()
        )

        // Switches
        Row(verticalAlignment = Alignment.CenterVertically) {
            Switch(checked = isBold, onCheckedChange = { isBold = it })
            Text("Полужирный", modifier = Modifier.padding(start = 8.dp))
        }
        Row(verticalAlignment = Alignment.CenterVertically) {
            Switch(checked = isItalic, onCheckedChange = { isItalic = it })
            Text("Курсив", modifier = Modifier.padding(start = 8.dp))
        }
    }
}








**Ответы на контрольные вопросы:**

**8.1** Какие элементы позволяют ввести текстовые значения?  
`OutlinedTextField` (или `TextField`) — основные элементы для ввода текста в Jetpack Compose.

**8.2** Как настроить тип клавиатуры?  
Через параметр `keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.XXX)`, где XXX — `Text`, `Password`, `Number`, `Phone`, `Email`, `Uri` и др.

**8.3** Как связать значение из элемента управления с переменной?  
С помощью `mutableStateOf()` и двух параметров:  
`value = переменная`, `onValueChange = { переменная = it }`.

**8.4** Для чего используется combobox, какие его основные настройки?  
Combobox (в Compose — `ExposedDropdownMenuBox`) используется для выбора одного значения из раскрывающегося списка.  
Основные настройки: `expanded`, `onExpandedChange`, `TextField` для отображения выбранного значения, `DropdownMenu` + `DropdownMenuItem`.

**8.5** Для чего используется radiobutton, какие его основные настройки?  
`RadioButton` используется для выбора **одного** варианта из группы.  
Основные настройки: `selected`, `onClick`. Для клика по всей строке добавляют `Modifier.selectable()`.

**8.6** Для чего используется slider, какие его основные настройки?  
`Slider` используется для выбора числового значения в заданном диапазоне (например, размер шрифта).  
Основные настройки: `value`, `onValueChange`, `valueRange`, `steps`.

**8.7** Для чего используется switch, какие его основные настройки?  
`Switch` — переключатель «вкл/выкл» (boolean).  
Основные настройки: `checked`, `onCheckedChange`.

