// Main.kt
// Проект: LabWork8
// Вариант 12 (ПК 12 — чётный) → Circle

import kotlin.math.PI
import kotlin.random.Random

// ====================== 5.1 + 5.2 ======================
open class Person(val name: String, val age: Int) {

    override fun toString(): String {
        return "Person: name=$name, age=$age"
    }

    open val fullInfo: String
        get() = "Name: $name\nAge: $age"

    open fun printInfo() {
        println(fullInfo)
    }
}

class Student(name: String, age: Int, val group: String) : Person(name, age) {

    override fun toString(): String {
        return "${super.toString()} | Student of group $group"
    }

    override val fullInfo: String
        get() = "${super.fullInfo}\nGroup: $group"

    override fun printInfo() {
        super.printInfo()
        println("Group: $group")
    }
}

// ====================== 5.3 ======================
abstract class Shape {
    abstract fun area(): Double
    abstract fun perimeter(): Double
    abstract fun printShapeInfo()
    abstract val shapeName: String
}

class Circle(val radius: Double) : Shape() {

    override val shapeName: String = "Circle"

    override fun area(): Double = PI * radius * radius
    override fun perimeter(): Double = 2 * PI * radius

    override fun printShapeInfo() {
        println("Shape name: $shapeName")
        println("Radius: $radius")
        println("Area: ${area()}")
        println("Perimeter: ${perimeter()}")
    }
}

// ====================== 5.4 ======================
interface DataSource<T> {
    fun getNext(): T
}

class RandomDataSource : DataSource<Int> {
    override fun getNext(): Int = Random.nextInt(1, 101)
}

class StaticDataSource<T>(private val items: Array<T>) : DataSource<T> {
    private var index = 0
    override fun getNext(): T {
        if (index >= items.size) index = 0
        return items[index++]
    }
}

fun print10Elements(source: DataSource<*>) {
    println("--- 10 elements from DataSource ---")
    repeat(10) {
        println(source.getNext())
    }
}

// ====================== 5.5 ======================
interface DeliveryService {
    val serviceName: String
    fun deliver(orderNumber: String)
}

class FoodDeliveryService(override val serviceName: String = "FoodExpress") : DeliveryService {
    override fun deliver(orderNumber: String) {
        println("Order $orderNumber has been sent to delivery via $serviceName")
    }
}

class DeliveryApp(private val service: DeliveryService) : DeliveryService by service {
    fun createOrder(orderNumber: String) {
        deliver(orderNumber)
    }
}

