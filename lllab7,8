// Country.kt  (отдельный файл для класса)
class Country(val name: String) {

    var capital: String = ""
        get() = field
        set(value) {
            if (value.isNotEmpty()) field = value
            else throw IllegalArgumentException("Capital cannot be empty")
        }

    var population: Long = 0
        get() = field
        set(value) {
            if (value >= 0) field = value
            else throw IllegalArgumentException("Population cannot be negative")
        }

    var area: Double = 0.0
        get() = field
        set(value) {
            if (value >= 0) field = value
            else throw IllegalArgumentException("Area cannot be negative")
        }

    init {
        // первичный конструктор
    }

    // вторичный конструктор
    constructor(
        name: String,
        capital: String,
        population: Long,
        area: Double
    ) : this(name) {
        this.capital = capital
        this.population = population
        this.area = area
    }

    // 5.3 Метод для вывода всей информации
    fun printAllInfo() {
        println("Name: $name")
        println("Capital: $capital")
        println("Population: $population")
        println("Area: $area km²")
    }

    // 5.3 Свойство на чтение (последний параметр — площадь)
    val areaInfo: String
        get() = "Area: $area km²"
}
