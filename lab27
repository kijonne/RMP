#### 1. `User.kt`
```kotlin
package com.example.labwork27

data class User(
    val login: String,
    val password: String,
    var aboutMe: String = ""
)
```

#### 2. `UserService.kt`
```kotlin
package com.example.labwork27

object UserService {
    private val users = mutableListOf<User>()

    fun register(user: User): Boolean {
        if (users.any { it.login == user.login }) return false
        users.add(user)
        return true
    }

    fun login(login: String, password: String): User? {
        return users.find { it.login == login && it.password == password }
    }

    fun getUser(login: String): User? {
        return users.find { it.login == login }
    }
}
```

#### 3. `RegisterViewModel.kt`
```kotlin
package com.example.labwork27

import androidx.compose.runtime.mutableStateOf
import androidx.lifecycle.ViewModel

class RegisterViewModel : ViewModel() {
    var login = mutableStateOf("")
    var password = mutableStateOf("")

    fun register(onSuccess: () -> Unit, onError: (String) -> Unit) {
        if (login.value.isBlank() || password.value.isBlank()) {
            onError("Заполните все поля")
            return
        }
        val user = User(login.value, password.value)
        if (UserService.register(user)) {
            login.value = ""
            password.value = ""
            onSuccess()
        } else {
            onError("Пользователь с таким логином уже существует")
        }
    }
}
```

#### 4. `LoginViewModel.kt`
```kotlin
package com.example.labwork27

import androidx.compose.runtime.mutableStateOf
import androidx.lifecycle.ViewModel

class LoginViewModel : ViewModel() {
    var login = mutableStateOf("")
    var password = mutableStateOf("")

    fun authorize(onSuccess: (String) -> Unit, onError: (String) -> Unit) {
        if (login.value.isBlank() || password.value.isBlank()) {
            onError("Заполните все поля")
            return
        }
        val user = UserService.login(login.value, password.value)
        if (user != null) {
            onSuccess(login.value)
        } else {
            onError("Неверный логин или пароль")
        }
    }
}
```

