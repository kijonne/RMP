**✅ ВСЁ ИСПРАВЛЕНО!**  

Проблема была в двух местах:  
1. У тебя в проекте функция темы называется **`LabWork23Theme`** (а не `MyAppTheme`).  
2. Не подключена зависимость `navigation-compose` + иконки Material.

### 1. Обнови `MainActivity.kt` (замени полностью)

```kotlin
package com.example.labwork23

import android.os.Bundle
import androidx.activity.ComponentActivity
import androidx.activity.compose.setContent
import androidx.compose.foundation.layout.padding
import androidx.compose.material.icons.Icons
import androidx.compose.material.icons.filled.DarkMode
import androidx.compose.material.icons.filled.LightMode
import androidx.compose.material.icons.filled.Menu
import androidx.compose.material.icons.filled.Settings
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Modifier
import androidx.navigation.compose.NavHost
import androidx.navigation.compose.composable
import androidx.navigation.compose.rememberNavController
import com.example.labwork23.screens.CartScreen
import com.example.labwork23.screens.HomeScreen
import com.example.labwork23.screens.ProfileScreen
import com.example.labwork23.ui.theme.LabWork23Theme   // ← теперь LabWork23Theme

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContent {
            val navController = rememberNavController()

            var isDarkTheme by remember { mutableStateOf(false) }
            var colorStyle by remember { mutableStateOf(1) }

            LabWork23Theme(isDarkTheme = isDarkTheme, colorStyle = colorStyle) {   // ← исправлено имя
                Scaffold(
                    topBar = {
                        TopAppBar(
                            title = { Text("TechShop") },
                            navigationIcon = {
                                IconButton(onClick = { }) {
                                    Icon(Icons.Filled.Menu, contentDescription = "Меню")
                                }
                            },
                            actions = {
                                IconButton(onClick = { isDarkTheme = !isDarkTheme }) {
                                    Icon(
                                        imageVector = if (isDarkTheme) Icons.Filled.LightMode else Icons.Filled.DarkMode,
                                        contentDescription = "Сменить тему"
                                    )
                                }
                                IconButton(onClick = { colorStyle = if (colorStyle == 1) 2 else 1 }) {
                                    Icon(Icons.Filled.Settings, contentDescription = "Сменить палитру")
                                }
                            }
                        )
                    }
                ) { paddingValues ->
                    NavHost(
                        navController = navController,
                        startDestination = "home",
                        modifier = Modifier.padding(paddingValues)
                    ) {
                        composable("home") { HomeScreen(navController) }
                        composable("cart") { CartScreen(navController) }
                        composable("profile") { ProfileScreen(navController) }
                    }
                }
            }
        }
    }
}
```

### 2. Обнови `Theme.kt` (замени полностью — меняем имя функции)

```kotlin
package com.example.labwork23.ui.theme

import androidx.compose.material3.darkColorScheme
import androidx.compose.material3.lightColorScheme
import androidx.compose.runtime.Composable
import androidx.compose.ui.graphics.Color
import androidx.compose.material3.MaterialTheme

// Палитра 1 (фиолетовая)
private val LightColorScheme1 = lightColorScheme(
    primary = Color(0xFF6750A4),
    secondary = Color(0xFF625B71),
    background = Color(0xFFFFFBFE),
    surface = Color(0xFFFFFBFE),
    onPrimary = Color.White,
    onSecondary = Color.White,
    onBackground = Color(0xFF1C1B1F),
    onSurface = Color(0xFF1C1B1F)
)

private val DarkColorScheme1 = darkColorScheme(
    primary = Color(0xFFD0BCFF),
    secondary = Color(0xFFCCC2DC),
    background = Color(0xFF1C1B1F),
    surface = Color(0xFF1C1B1F),
    onPrimary = Color(0xFF381E72),
    onSecondary = Color(0xFF332D41),
    onBackground = Color(0xFFE6E1E5),
    onSurface = Color(0xFFE6E1E5)
)

// Палитра 2 (бирюзовая)
private val LightColorScheme2 = lightColorScheme(
    primary = Color(0xFF00BFA5),
    secondary = Color(0xFF009688),
    background = Color(0xFFF5F5F5),
    surface = Color(0xFFF5F5F5),
    onPrimary = Color.White,
    onSecondary = Color.White,
    onBackground = Color(0xFF212121),
    onSurface = Color(0xFF212121)
)

private val DarkColorScheme2 = darkColorScheme(
    primary = Color(0xFF00BFA5),
    secondary = Color(0xFF009688),
    background = Color(0xFF212121),
    surface = Color(0xFF212121),
    onPrimary = Color.Black,
    onSecondary = Color.Black,
    onBackground = Color(0xFFE0E0E0),
    onSurface = Color(0xFFE0E0E0)
)

@Composable
fun LabWork23Theme(          // ← ИМЯ ИЗМЕНЕНО НА LabWork23Theme
    isDarkTheme: Boolean,
    colorStyle: Int,
    content: @Composable () -> Unit
) {
    val colorScheme = when (colorStyle) {
        1 -> if (isDarkTheme) DarkColorScheme1 else LightColorScheme1
        else -> if (isDarkTheme) DarkColorScheme2 else LightColorScheme2
    }

    MaterialTheme(
        colorScheme = colorScheme,
        typography = Typography,
        content = content
    )
}
```

### 3. Добавь зависимость (чтобы исчезли ошибки с `rememberNavController`, `composable` и т.д.)

Открой файл **`build.gradle.kts (Module: app)`**  
Найди блок `dependencies {` и добавь строку:

```kotlin
implementation("androidx.navigation:navigation-compose:2.7.7")
implementation("androidx.compose.material:material-icons-extended")   // для иконок LightMode/DarkMode
```

После этого нажми **Sync Now** в правом верхнем углу.

### Что делать дальше:
1. Замени оба файла полностью (MainActivity.kt и Theme.kt).
2. Добавь зависимость и нажми **Sync Now**.
3. **Build → Rebuild Project**.

После этого должно остаться 0 ошибок.

Если после Sync всё равно будут красные подчёркивания — нажми **File → Invalidate Caches → Invalidate and Restart**.

Напиши, если после этого что-то ещё осталось — пришлёшь новый скриншот и сразу починим!  
