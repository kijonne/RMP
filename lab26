### 6. `MainActivity.kt` (самое важное — навигация)

Замени весь код в `MainActivity.kt`:

```kotlin
package com.example.labwork26

import android.os.Bundle
import androidx.activity.ComponentActivity
import androidx.activity.compose.setContent
import androidx.navigation.compose.NavHost
import androidx.navigation.compose.composable
import androidx.navigation.compose.rememberNavController
import androidx.lifecycle.viewmodel.compose.viewModel
import com.example.labwork26.ui.*
import com.example.labwork26.viewmodel.UserViewModel

class MainActivity : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        setContent {
            val navController = rememberNavController()
            val viewModel: UserViewModel = viewModel()

            NavHost(navController = navController, startDestination = "main") {
                composable("main") {
                    MainScreen(
                        viewModel = viewModel,
                        onUserClick = { login -> navController.navigate("user/$login") },
                        onAddClick = { navController.navigate("add") }
                    )
                }

                composable("add") {
                    AddUserScreen(
                        viewModel = viewModel,
                        onBack = { navController.popBackStack() }
                    )
                }

                composable("user/{login}") { backStackEntry ->
                    val login = backStackEntry.arguments?.getString("login") ?: ""
                    UserDetailScreen(
                        login = login,
                        viewModel = viewModel,
                        onBack = { navController.popBackStack() }
                    )
                }
            }
        }
    }
}
```

