### 2. `UserViewModel.kt`

**Пакет:** `viewmodel` → файл `UserViewModel.kt`

```kotlin
package com.example.labwork26.viewmodel

import androidx.compose.runtime.mutableStateListOf
import androidx.lifecycle.ViewModel
import com.example.labwork26.data.User

class UserViewModel : ViewModel() {

    private val _users = mutableStateListOf<User>()
    val users: List<User> get() = _users

    // Добавление пользователя
    fun addUser(login: String, password: String, email: String) {
        _users.add(User(login, password, email))
    }

    // Получение пользователя по логину
    fun getUserByLogin(login: String): User? {
        return _users.find { it.login == login }
    }

    // Редактирование пользователя (логин менять нельзя)
    fun updateUser(login: String, newPassword: String, newEmail: String) {
        val index = _users.indexOfFirst { it.login == login }
        if (index != -1) {
            _users[index] = _users[index].copy(password = newPassword, email = newEmail)
        }
    }

    // Удаление пользователя
    fun deleteUser(login: String) {
        _users.removeAll { it.login == login }
    }
}
```

