/**
 * Data class для хранения логина и пароля пользователя.
 * Логин и пароль объявлены в основном конструкторе.
 *
 * @param login логин пользователя
 * @param password пароль пользователя
 * @property login логин
 * @property password пароль
 * @author Шубина А.С., Давудова Д.И.
 * @since 2026
 * @sample User("user", "pass123")
 */
data class User(val login: String, val password: String) {

    /**
     * Проверяет совпадение переданного пароля с паролем пользователя.
     *
     * @param inputPassword проверяемый пароль
     * @return true — если пароли совпадают, false — иначе
     * @author Шубина А.С., Давудова Д.И.
     * @since 2026
     * @sample User("user", "pass123").checkPassword("pass123")
     */
    fun checkPassword(inputPassword: String): Boolean {
        return inputPassword == password
    }
}
